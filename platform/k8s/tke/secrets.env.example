sql-dsn=postgres://router:replace-with-url-encoded-postgres-password@postgres.aether-relay.svc.cluster.local:5432/router?sslmode=disable
postgres-password=replace-with-postgres-password
router-api-key=replace-with-public-relay-key
router-admin-key=replace-with-admin-key
api-key-hash-secret=replace-with-random-hmac-secret
account-service-key=replace-with-account-service-bearer-key
openrouter-api-key=replace-with-openrouter-api-key
