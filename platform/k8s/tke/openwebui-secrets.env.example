# Open WebUI runtime secrets. Copy to openwebui-secrets.env and fill in.
# This file contains placeholders only; never commit real credentials.
#
#   cp platform/k8s/tke/openwebui-secrets.env.example \
#      platform/k8s/tke/openwebui-secrets.env
#
# openwebui-relay-api-key: a relay API key created via the account service
#   (see platform/RUNBOOK.md section 9). Open WebUI sends this as the
#   OpenAI-compatible Authorization bearer token to the in-cluster relay.
# webui-secret-key: random secret used by Open WebUI for session signing.
#   Generate with: openssl rand -base64 32
openwebui-relay-api-key=replace-with-relay-api-key
webui-secret-key=replace-with-random-webui-secret-key
